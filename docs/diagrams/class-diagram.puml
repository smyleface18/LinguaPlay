@startuml
left to right direction
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 30

package "Database Entities (TypeORM)" {
  together {
  class CoreEntity {
    +id: uuid
    +active: boolean
    +createdAt: Date
    +updatedAt: Date
  }

  class User {
    +username: string
    +email: string
    +score: number
    +userRole: UserRoles
    +level: Level
    +avatar: S3Object
    +role: UserRoles
  }

  class Game {
    +difficulty: Level
  }

  class GameSession {
    +userId: uuid
    +gameId: uuid
    +score: number
    +position: number
  }

  class CategoryQuestion {
    +level: Level
    +descriptionCategory: string
    +type: TypeQuestionCategory
  }

  class Question {
    +content: ContentObject
    +moreInfo: string
    +categoryId: uuid
    +timeLimit: number
  }

  class QuestionOption {
    +content: ContentObject
    +isCorrect: boolean
    +questionId: uuid
  }

  class PlayerAnswer {
    +gameSessionId: uuid
    +questionId: uuid
    +selectedOptionId: uuid
    +isCorrect: boolean
    +timeTaken: number
  }
  }

  together {
  class ContentObject {
    +type: ContentType
    +value: string
    +meta: S3Object
  }

  class S3Object {
    +key: string
    +type: string
    +displayName: string
    +url: string
    +bucketName: string
  }
  }

  enum Level {
    A1
    A2
    B1
    B2
    C1
    C2
  }

  enum ContentType {
    TEXT
    IMAGE
    AUDIO
    VIDEO
  }

  enum TypeQuestionCategory {
    LISTENING
    GRAMMAR
    READING
    VOCABULARY
    WRITING
    SPEAKING
  }

  enum UserRoles {
    PLAYER
    ADMIN
  }
}

package "Game Domain (in-memory/cache)" {
  class Match {
    -roomId: string
    -status: MatchStatus
    -currentQuestionIndex: number
    -players: Map<string, PlayerInfo>
    -difficulty: Level
    -mode: ModeMatch
    +getRoomId(): string
    +getDifficulty(): Level
    +getMode(): ModeMatch
    +addPlayer(userId: string, username: string, level: Level, totalScore: number, isOwner: boolean, avatar: string): void
    +disconnectPlayer(userId: string): void
    +reconnectPlayer(userId: string): void
    +isUserConnected(userId: string): boolean
    +getPlayersCount(): number
    +getPlayers(): string[]
    +getPlayersWithInfo(): PlayerInfo[]
    +sendNextQuestion(): Question
    +addScore(userId: string, points: number): void
    +finishCurrentQuestion(): void
    +hasNextQuestion(): boolean
    +getResults(): PlayerInfo[]
    +getStatus(): MatchStatus
    +getQuestions(): Question[]
    +getQuestionById(questionId: string): Question
    +getOwner(): User
    +start(): void
    +getcurrentQuestionIndex(): number
    +calculateMatchTimeout(): number
    +getNextQuestion(): Question
    +toPersistence(): any
    +isRoomEmpty(): boolean
    +setStatus(status: MatchStatus): void
    {static} +fromPersistence(data: unknown): Match
  }

  class PlayerInfo {
    +userId: string
    +username: string
    +level: Level
    +matchScore: number
    +totalScore: number
    +isConnected: boolean
    +isOwner: boolean
    +avatar: string
  }

  enum MatchStatus {
    WAITING
    QUESTION_ACTIVE
    PROCESSING
    BETWEEN_QUESTIONS
    FINISHED
    STARTING
    PREPARING
  }

  enum ModeMatch {
    SINGLEPLAYER
    MULTIPLAYER
  }
}

User -[hidden]- Game
Game -[hidden]- GameSession
CategoryQuestion -[hidden]- Question
Question -[hidden]- QuestionOption
GameSession -[hidden]- PlayerAnswer
Question -[hidden]- ContentObject
ContentObject -[hidden]- S3Object

CoreEntity <|-- User
CoreEntity <|-- Game
CoreEntity <|-- GameSession
CoreEntity <|-- CategoryQuestion
CoreEntity <|-- Question
CoreEntity <|-- QuestionOption
CoreEntity <|-- PlayerAnswer

User "1" -- "0..*" GameSession : sessions
Game "1" -- "0..*" GameSession : sessions
Game "*" -- "*" Question : questions
CategoryQuestion "1" -- "0..*" Question : questions
Question "1" -- "0..*" QuestionOption : options
GameSession "1" -- "0..*" PlayerAnswer : answers
Question "1" -- "0..*" PlayerAnswer
QuestionOption "1" -- "0..*" PlayerAnswer

Question --> ContentObject
QuestionOption --> ContentObject
ContentObject --> S3Object : meta
User --> S3Object : avatar
User --> UserRoles

Match "1" o-- "*" PlayerInfo : players
Match --> Level
Match --> ModeMatch
Match --> MatchStatus

User --> Level
CategoryQuestion --> Level
CategoryQuestion --> TypeQuestionCategory
ContentObject --> ContentType

@enduml
